{
	"name": "mcp-registry",
	"version": "0.1.0",
	"description": "Internal MCP Server Registry",
	"scripts": {
		"dev": "npx http-server -p 8080 .",
		"test": "node --test",
		"test:registry": "node --test tests/registry.test.js",
		"test:secrets": "node --test tests/secrets.test.js",
		"test:versions": "node --test tests/version.test.js",
		"update:packages": "node scripts/update-packages.js",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check --write .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"ajv": "^8.0.0",
		"ajv-formats": "^2.1.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0"
	},
	"engines": {
		"node": ">=24"
	},
	"lint-staged": {
		"*.{json,js}": [
			"biome check --write"
		],
		"v0.1/servers": [
			"biome check --write"
		]
	}
}
