{
  "name": "Internal MCP Server Registry",
  "description": "Whitelist of approved Model Context Protocol (MCP) servers.",
  "version": "1.0.0",
  "mcpServers": {
    "mksglu/context-mode": {
      "name": "mksglu/context-mode",
      "description": "Virtualization layer optimizing context window usage via sandboxed tool outputs.",
      "version": "1.0.0",
      "packages": [
        {
          "registryType": "npm",
          "identifier": "context-mode",
          "transport": {
            "type": "stdio"
          }
        }
      ]
    },
    "ChromeDevTools/chrome-devtools-mcp": {
      "name": "ChromeDevTools/chrome-devtools-mcp",
      "description": "Chrome DevTools MCP server for interacting with Chrome via the DevTools Protocol.",
      "version": "1.0.0",
      "packages": [
        {
          "registryType": "npm",
          "identifier": "chrome-devtools-mcp",
          "packageArguments": [
            {
              "type": "positional",
              "value": "--browser-url=${browser_url}"
            },
            {
              "type": "positional",
              "value": "--no-usage-statistics"
            },
            {
              "type": "positional",
              "value": "--no-performance-crux"
            }
          ],
          "transport": {
            "type": "stdio"
          }
        }
      ]
    }
  }
}